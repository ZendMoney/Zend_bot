# ─── Telegram Bot ───
BOT_TOKEN=your_telegram_bot_token

# ─── Database ───
DATABASE_URL=postgres://zend:zend_dev_password@localhost:5432/zend

# ─── Redis (optional — sessions persist across restarts when set) ───
REDIS_URL=redis://localhost:6379

# ─── Solana ───
# Use mainnet for production; devnet for local testing only
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── PAJ Protocol (NGN On/Off-Ramp) ───
PAJ_BUSINESS_API_KEY=your_paj_business_api_key
PAJ_WEBHOOK_SECRET=your_paj_webhook_secret
PAJ_ENVIRONMENT=Production

# ─── Zend Wallets ───
# Dev wallet — funds SOL for gasless users (base58 secret key)
ZEND_DEV_WALLET_SECRET=your_dev_wallet_base58_secret_key
# Legacy alias for ZEND_DEV_WALLET_SECRET (optional)
# PV_KEY=
# Collects Zend fees on sends (Solana USDT address)
ZEND_FEE_WALLET=your_solana_fee_collection_address

# ─── Zend Fees (bank sends / off-ramp) ───
# Normal (user has SOL): ZEND_FEE_BPS % capped at ZEND_FEE_CAP_USDT
# Gas sponsored: max(ZEND_FEE_FUNDED_BPS %, SOL-funded USDT + ZEND_GAS_EXTRA_FLAT_USDT)
ZEND_FEE_BPS=100
ZEND_FEE_CAP_USDT=2
ZEND_FEE_FUNDED_BPS=150
ZEND_FEE_FUNDED_CAP_USDT=3
ZEND_GAS_EXTRA_FLAT_USDT=0.25

# ─── Feature flags ───
# AUDD hidden by default — set true to re-enable menus
ZEND_AUDD_ENABLED=false

# ─── Admin (numeric Telegram user IDs only — not usernames) ───
ADMIN_TELEGRAM_IDS=123456789,987654321
# Legacy singular alias (optional — ADMIN_TELEGRAM_IDS takes precedence)
# ADMIN_TELEGRAM_ID=
SUPER_ADMIN_TELEGRAM_IDS=123456789

# ─── NEAR Intents (Cross-Chain Deposits & Withdrawals) ───
NEAR_INTENTS_JWT=
NEAR_INTENTS_API_URL=https://1click.chaindefuser.com/v0
NEAR_INTENTS_REFUND_ADDRESS=zend-refund.near

# ─── AirBills (Nigerian Bill Payments) ───
AIRBILLS_API_KEY=your_airbills_api_key
AIRBILLS_BASE_URL=https://api.airbills.org/v1

# ─── VTpass (fallback bill payments when AirBills not configured) ───
VTPASS_API_KEY=
VTPASS_API_URL=https://sandbox.vtpass.com/api

# ─── Chainrails (optional) ───
CHAINRAILS_API_KEY=
CHAINRAILS_API_URL=https://api.chainrails.io/api/v1

# ─── Encryption ───
# 64-char hex key for wallet encryption (required in production)
ENCRYPTION_KEY=your_64_char_hex_key

# ─── QVAC Local AI ───
QVAC_MODEL_DIR=./models
QVAC_USE_LIGHT_MODELS=true

# ─── Legacy NLP (optional — QVAC is primary) ───
OPENAI_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding
KIMI_MODEL=kimi-for-coding

# ─── Bot UX ───
# Auto-delete DM messages (minutes)
MESSAGE_TTL_MINUTES=12
PIN_TTL_MINUTES=2

# ─── Server / Webhooks ───
API_PORT=3001
PORT=3001
WEBHOOK_PORT=3001
WEBHOOK_BASE_URL=https://your-app.up.railway.app
NODE_ENV=production

# Railway sets RAILWAY_PUBLIC_DOMAIN automatically — do not set manually
# RAILWAY_PUBLIC_DOMAIN=