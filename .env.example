# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_URL=postgres://zend:zend_dev_password@localhost:5432/zend

# Redis
REDIS_URL=redis://localhost:6379

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# Base64-encoded fee payer secret key
FEE_PAYER_KEY=base64_encoded_secret_key_here

# PAJ Protocol
PAJ_API_KEY=your_paj_api_key
PAJ_API_SECRET=your_paj_api_secret
PAJ_BASE_URL=https://api.paj.cash

# API
API_PORT=3000

# Kimi AI (Moonshot) - Primary AI for NLU
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# Optional: OpenAI (fallback for voice/vision)
OPENAI_API_KEY=your_openai_key
