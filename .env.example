# ─── Telegram Bot ───
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token

# ─── Database ───
# PostgreSQL connection string
DATABASE_URL=postgres://zend:zend_dev_password@localhost:5432/zend

# ─── Redis ───
# For session storage and caching
REDIS_URL=redis://localhost:6379

# ─── Solana ───
# RPC endpoint (devnet for testing, mainnet for production)
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── PAJ Protocol (NGN On/Off-Ramp) ───
# Get your business API key from: https://paj.cash
# Auth flow: initiate(email) → OTP → verify() → sessionToken
PAJ_BUSINESS_API_KEY=your_paj_business_api_key
PAJ_ENVIRONMENT=Production  # or Staging

# ─── API Server ───
API_PORT=3001

# ─── Optional: OpenAI (for NLU/Voice features) ───
OPENAI_API_KEY=your_openai_key

# Encryption
ENCRYPTION_KEY=your_64_char_hex_key

# Kimi (Moonshot AI) for NLP/Voice — DEPRECATED: Zend now uses QVAC local AI
KIMI_API_KEY=your_kimi_key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ─── QVAC Local AI ───
# QVAC runs AI models locally — no API keys needed.
# Models are downloaded automatically on first use.
# Set QVAC_MODEL_DIR to customize where models are cached (default: ./models)
QVAC_MODEL_DIR=./models

# Zend Fee (basis points: 100 = 1%, 50 = 0.5%)
ZEND_FEE_BPS=100

# Fee wallet (receives Zend fees — must be a Solana address)
ZEND_FEE_WALLET=your_solana_fee_wallet_address

# Dev wallet (funds SOL for gasless users — base58 secret key)
ZEND_DEV_WALLET_SECRET=your_dev_wallet_base58_secret_key

# ─── ChainRails (Cross-Chain Deposits) ───
# Get API key from: https://chainrails.io
CHAINRAILS_API_KEY=your_chainrails_api_key
CHAINRAILS_API_URL=https://api.chainrails.io/api/v1
# Optional: secret token to verify ChainRails webhooks
CHAINRAILS_WEBHOOK_SECRET=your_random_webhook_secret

# ─── Railway / Webhooks ───
WEBHOOK_BASE_URL=https://your-app.up.railway.app
