{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@zend/shared": ["packages/shared/src"],
      "@zend/solana": ["packages/solana/src"],
      "@zend/paj-client": ["packages/paj-client/src"],
      "@zend/db": ["packages/db/src"],
      "@zend/nlu": ["packages/nlu/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
